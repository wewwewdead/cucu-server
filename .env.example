# Copy to `.env` for local dev. On Railway, set these as service variables (never commit real values).

# Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Service-role key — full DB access, bypasses RLS. SERVER-ONLY. Never ship to the app.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret (Supabase → Settings → API → JWT Settings → JWT Secret). Used to verify user
# access tokens locally, with no per-request round trip to Supabase.
SUPABASE_JWT_SECRET=

# Port the HTTP server listens on. Railway injects PORT automatically; 8080 for local dev.
PORT=8080
